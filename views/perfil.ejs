<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <title>Perfil do Utilizador</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="/img/logo-fitcheck.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#00796b">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="FitCheck">
  <link rel="stylesheet" href="/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">
  <style>
    body { display: flex; flex-direction: column; min-height: 100vh; }
    .dashboard-container {
      margin-top: 80px;
      max-width: 400px;
      margin-inline: auto;
      padding: 20px;
      text-align: center;
    }
    form { align-items: center; }
    label { align-self: flex-start; max-width: 260px; }
    input { max-width: 260px; }
  </style>
</head>
<body>
  <%- include('partials/topbar') %>

  <div class="dashboard-container">
    <h1>Atualizar Perfil</h1>

    <section class="info-box">
      <% if (typeof error !== 'undefined') { %>
        <p class="error"><%= error %></p>
      <% } %>
      <% if (typeof success !== 'undefined') { %>
        <p class="success"><%= success %></p>
      <% } %>

      <form method="POST" action="/perfil">
        <label for="idade">Idade:</label>
        <input type="number" id="idade" name="idade" required value="<%= typeof idade !== 'undefined' ? idade : '' %>">

        <label for="altura">Altura (em metros):</label>
        <input type="number" step="0.01" id="altura" name="altura" required value="<%= typeof altura !== 'undefined' ? altura : '' %>">

        <label for="peso">Peso (em kg):</label>
        <input type="number" step="0.1" id="peso" name="peso" required value="<%= typeof peso !== 'undefined' ? peso : '' %>">

        <button type="submit">Salvar</button>
      </form>
    </section>

   
  </div>
</body>
</html>

