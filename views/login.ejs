<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <title>Login - FitCheck</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/style.css">
  <style>
    body {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding-top: 100px;
      min-height: 100vh;
    }
    h1 { margin-bottom: 24px; text-align: center; }
    .info-box { max-width: 400px; width: 100%; text-align: center; }
    form { align-items: center; }
    input { max-width: 280px; }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="logo">
      <img src="/img/logo-fitcheck.png" alt="Logo"> FitCheck
    </div>
    <nav>
      <a href="/register">Criar Conta</a>
    </nav>
  </header>

  <h1>Entrar no FitCheck</h1>

  <section class="info-box">
    <% if (typeof error !== 'undefined') { %>
      <p class="error"><%= error %></p>
    <% } %>

    <form method="POST" action="/auth/login">
      <label for="email">Email:</label>
      <input type="email" id="email" name="email" required>

      <label for="senha">Senha:</label>
      <input type="password" id="senha" name="senha" required>

      <button type="submit">Entrar</button>
    </form>
  </section>
</body>
</html>
