<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <title>Criar Conta - FitCheck</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="/img/logo-fitcheck.png">
  <link rel="stylesheet" href="/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">
  <style>
    body { display: flex; flex-direction: column; min-height: 100vh; }
    .dashboard-container {
      margin-top: 80px;
      max-width: 400px;
      margin-inline: auto;
      padding: 20px;
      text-align: center;
    }
    form { align-items: center; }
    label { align-self: flex-start; max-width: 260px; }
    input, select { max-width: 260px; }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="logo">
      <img src="/img/logo-fitcheck.png" alt="Logo">
      FitCheck
    </div>
    <nav>
      <a href="/login">Entrar</a>
      <a href="/">Início</a>
    </nav>
  </header>

  <div class="dashboard-container">
    <h1>Registar nova conta</h1>

    <section class="info-box">
      <% if (typeof error !== 'undefined') { %>
        <p class="error"><%= error %></p>
      <% } %>

      <form method="POST" action="/auth/register">
        <label for="nome">Nome:</label>
        <input type="text" id="nome" name="nome" required>

        <label for="email">Email:</label>
        <input type="email" id="email" name="email" required>

        <label for="senha">Senha:</label>
        <input type="password" id="senha" name="senha" required>

        <label for="tipo">Tipo de conta:</label>
        <select id="tipo" name="tipo">
          <option value="comum" selected>Comum</option>
          <option value="pro">Pro</option>
        </select>

        <button type="submit">Criar Conta</button>
      </form>
    </section>

    <div class="button-group">
      <a href="/login"><button>🔐 Já tem conta?</button></a>
    </div>
  </div>
</body>
</html>
