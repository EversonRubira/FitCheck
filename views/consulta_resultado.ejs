<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <title>Resultado da Consulta</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/style.css">
  <link rel="icon" type="image/png" href="/img/logo-fitcheck.png">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">
  <style>
    body { padding-top: 80px; }
    .dashboard-container { max-width: 520px; margin: 0 auto; padding: 30px 20px; text-align: center; }
    .info-box { margin-bottom: 30px; }
    ul { margin: 0 auto; max-width: 320px; line-height: 1.8; text-align: left; }
    li strong { color: var(--primary, #00897b); }
  </style>
</head>
<body>
  <%- include('partials/topbar') %>

  <div class="dashboard-container">
    <h2>Registo de <%= data %></h2>

    <section class="info-box">
      <% if (notFound) { %>
        <p class="error">Nenhum registo encontrado para <%= data %>.</p>
      <% } else { %>
        <ul>
          <li><strong>Sono:</strong> <%= horasSono %>h (<%= qualidadeSono %>)</li>
          <li><strong>Água:</strong> <%= aguaMl %>ml</li>
          <li><strong>Humor:</strong> <%= humor %>/5</li>
          <li><strong>Atividade:</strong> <%= tipoAtividade %> (<%= intensidade %>)</li>
          <li><strong>Alimentação:</strong> <%= qualidadeAlimentacao %>/5</li>
        </ul>
      <% } %>
    </section>

    <div class="button-group">
      <a href="/dashboard"><button>⬅ Voltar ao Dashboard</button></a>
    </div>
  </div>
</body>
</html>
