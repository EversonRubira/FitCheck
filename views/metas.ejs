<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <title>Definir Metas - FitCheck</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="/img/logo-fitcheck.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#00796b">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="FitCheck">
  <link rel="stylesheet" href="/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">
  <style>
    body { display: flex; flex-direction: column; min-height: 100vh; }
    .dashboard-container {
      margin-top: 80px;
      max-width: 400px;
      margin-inline: auto;
      padding: 20px;
      text-align: center;
    }
    form { align-items: center; }
    label { align-self: flex-start; max-width: 260px; }
    input { max-width: 260px; }
  </style>
</head>
<body>
  <%- include('partials/topbar') %>

  <div class="dashboard-container">
    <h1>Definir Metas Pessoais</h1>

    <section class="info-box">
      <% if (typeof error !== 'undefined') { %>
        <p class="error"><%= error %></p>
      <% } %>
      <% if (typeof success !== 'undefined') { %>
        <p class="success"><%= success %></p>
      <% } %>

      <form method="POST" action="/metas">
        <label for="pesoIdeal">Peso Ideal (kg):</label>
        <input type="number" step="0.1" id="pesoIdeal" name="pesoIdeal" required
               value="<%= typeof pesoIdeal !== 'undefined' ? pesoIdeal : '' %>">

        <label for="sonoMinimo">Meta de Sono (horas por noite):</label>
        <input type="number" id="sonoMinimo" name="sonoMinimo" required
               value="<%= typeof sonoMinimo !== 'undefined' ? sonoMinimo : '' %>">

        <label for="aguaDiariaMl">Meta de Água (ml por dia):</label>
        <input type="number" id="aguaDiariaMl" name="aguaDiariaMl" required
               value="<%= typeof aguaDiariaMl !== 'undefined' ? aguaDiariaMl : '' %>">

        <button type="submit">Salvar Metas</button>
      </form>
    </section>


  </div>
</body>
</html>
