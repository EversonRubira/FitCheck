<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <title>Análise da Semana</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="/img/logo-fitcheck.png">
  <link rel="stylesheet" href="/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">
  <style>
    body { padding-top: 80px; }
    .container {
      max-width: 800px;
      margin: 40px auto;
      padding: 40px;
    }
    .analise-texto { line-height: 1.8; white-space: pre-wrap; text-align: left; }
    .analise-texto .cursor {
      display: inline-block;
      width: 2px;
      height: 1em;
      background: var(--primary, #00897b);
      margin-left: 2px;
      vertical-align: text-bottom;
      animation: piscar 0.8s step-end infinite;
    }
    @keyframes piscar { 50% { opacity: 0; } }
    .aviso-limite {
      background: var(--primary-ghost, rgba(0, 137, 123, 0.12));
      border: 1.5px solid var(--primary, #00897b);
      color: var(--text-primary, #1a2e2b);
      border-radius: 12px;
      padding: 14px 18px;
      margin-bottom: 24px;
      font-size: 0.95rem;
    }
    .limite-box {
      text-align: center;
      background: rgba(229, 57, 53, 0.08);
      border: 1.5px solid var(--danger, #e53935);
      border-radius: 12px;
      padding: 24px;
      margin-bottom: 24px;
    }
  </style>
</head>
<body>
  <%- include('partials/topbar') %>
  <div class="container" style="margin-top: 80px;">
    <h1>Análise da tua semana</h1>

    <% if (limiteAtingido) { %>
      <div class="limite-box">
        <p>Atingiste o limite de <%= limite %> análises de teste. Obrigado por experimentar o FitCheck!</p>
      </div>
    <% } else { %>
      <div class="aviso-limite">
        Tens direito a <%= limite %> análises gratuitas. Estás a usar a análise <%= numeroAnalise %> de <%= limite %>.
      </div>
      <p class="analise-texto" id="analise-texto"><span class="cursor"></span></p>
    <% } %>

    <a href="/registros/historico"><button class="btn">⬅ Voltar ao Histórico</button></a>
  </div>

  <% if (!limiteAtingido) { %>
    <script src="/analise.js"></script>
  <% } %>
</body>
</html>