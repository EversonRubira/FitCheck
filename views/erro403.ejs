<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <title>🚫 Acesso Negado - FitCheck</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/style.css">
  <link rel="icon" href="/img/logo-fitcheck.png" type="image/png">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">
  <style>
    body {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      padding-top: 60px;
    }
    .erro-box {
      text-align: center;
      max-width: 420px;
      width: 100%;
      padding: 32px 24px;
    }
    .erro-box img { width: 64px; margin-bottom: 14px; }
    .erro-box h1 { color: #c62828; }
    .erro-box p { margin-bottom: 20px; }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="logo">
      <img src="/img/logo-fitcheck.png" alt="Logo FitCheck"> FitCheck
    </div>
  </header>

  <div class="erro-box">
    <img src="https://cdn-icons-png.flaticon.com/512/463/463612.png" alt="Proibido">
    <h1>🚫 Acesso Negado</h1>
    <p><%= mensagem %></p>

    <div class="button-group">
      <a href="/dashboard"><button>⬅ Voltar ao Dashboard</button></a>
    </div>
  </div>
</body>
</html>
