<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <title>Histórico de Registos</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="/img/logo-fitcheck.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#00796b">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="FitCheck">
  <link rel="stylesheet" href="/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">
  <style>
    body { padding-top: 80px; }
    .dashboard-container { max-width: 1000px; margin: 0 auto; padding: 40px 20px; text-align: center; }

    .table-header-fixed {
      display: grid;
      grid-template-columns: 40% 15% 15% 15% 15%;
      background: linear-gradient(135deg, #00897b, #00695c);
      color: white;
      font-weight: 600;
      font-size: 0.85rem;
      padding: 12px 0;
      border-radius: 12px;
      margin: 0 auto 8px auto;
    }

    .table-wrapper {
      background: rgba(255, 255, 255, 0.88);
      border-radius: 12px;
      box-shadow: 0 8px 24px rgba(0, 105, 92, 0.13);
      overflow-y: auto;
      max-height: 380px;
    }

    .pagination {
      margin-top: 20px;
      display: flex;
      justify-content: center;
      gap: 6px;
      flex-wrap: wrap;
    }

    .pagination a {
      padding: 7px 13px;
      border: 1.5px solid #00897b;
      border-radius: 50px;
      background: rgba(255,255,255,0.8);
      color: #00897b;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.88rem;
      transition: all 0.2s ease;
    }

    .pagination a.active,
    .pagination a:hover {
      background: linear-gradient(135deg, #00897b, #00695c);
      color: white;
      border-color: transparent;
    }
  </style>
</head>
<body>
  <%- include('partials/topbar') %>

  <div class="dashboard-container">
    <h1>Histórico Recente</h1>

    <div class="table-header-fixed">
      <div>Data</div>
      <div>Sono</div>
      <div>Água</div>
      <div>Humor</div>
      <div>Alim.</div>
    </div>

    <div class="table-wrapper">
      <table>
         <colgroup>
      <col style="width: 40%">
      <col style="width: 15%">
      <col style="width: 15%">
      <col style="width: 15%">
      <col style="width: 15%">
    </colgroup>
        <tbody>
          <% registros.forEach(function(r) { %>
            <tr>
              <td><%= r.data %></td>
              <td><%= r.horasSono || '-' %>h</td>
              <td><%= r.aguaMl || '-' %>ml</td>
              <td>
                <%= r.humor %>/5
                <%= r.humor == 5 ? '😁' : r.humor == 4 ? '😊' : r.humor == 3 ? '😐' : r.humor == 2 ? '😕' : '😞' %>
              </td>
              <td>
                <%= r.qualidadeAlimentacao %>/5
                <%= r.qualidadeAlimentacao == 5 ? '🌿' : r.qualidadeAlimentacao == 4 ? '🥗' : r.qualidadeAlimentacao == 3 ? '🍛' : r.qualidadeAlimentacao == 2 ? '🥪' : '🍔' %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (totalPages > 1) { %>
      <div class="pagination">
        <% for (let i = 1; i <= totalPages; i++) { %>
          <a href="?page=<%= i %>" class="<%= i === currentPage ? 'active' : '' %>"><%= i %></a>
        <% } %>
      </div>
    <% } %>

    <div class="button-group">
      <a href="/dashboard"><button>⬅ Voltar ao Dashboard</button></a>
      <% if (userTipo === 'pro') { %>
    <a href="/registros/analise"><button>🤖 Analisar minha semana</button></a>
  <% } %>
    </div>
  </div>
</body>
</html>
