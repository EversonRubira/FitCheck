<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <title>Registo Diário - FitCheck</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="/img/logo-fitcheck.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#00796b">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="FitCheck">
  <link rel="stylesheet" href="/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">
  <style>
    html, body { overflow-x: hidden; overflow-y: auto; }
    .dashboard-container {
      margin-top: 80px;
      max-width: 520px;
      margin-inline: auto;
      padding: 20px;
      text-align: center;
    }
    .info-box { margin-top: 16px; }
    form { align-items: center; }
    form label { text-align: left; max-width: 300px; width: 100%; }
    form input, form select { max-width: 300px; }
  </style>
</head>
<body>
  <%- include('partials/topbar') %>

  <div class="dashboard-container">
    <h1>Registo Diário</h1>

    <% if (typeof error !== 'undefined' && error) { %>
      <p class="error"><%= error %></p>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
      <p class="success"><%= success %></p>
    <% } %>

    <%
    var qs = typeof qualidadeSono !== 'undefined' ? qualidadeSono : '';
    var intensidadeVal = typeof intensidade !== 'undefined' ? intensidade : '';
    var humor = typeof humor !== 'undefined' ? humor : '';
    var qualidadeAlimentacao = typeof qualidadeAlimentacao !== 'undefined' ? qualidadeAlimentacao : '';
    %>

    <section class="info-box">
      <form method="POST" action="/registros">
        <label for="data">Data:</label>
        <input type="date" id="data" name="data" required value="<%= typeof data !== 'undefined' ? data : '' %>">

        <label for="horasSono">Horas de Sono:</label>
        <input type="number" id="horasSono" name="horasSono" required value="<%= typeof horasSono !== 'undefined' ? horasSono : '' %>">

        <label for="qualidadeSono">Qualidade do Sono:</label>
        <select id="qualidadeSono" name="qualidadeSono">
          <option value="ruim" <%= qs === 'ruim' ? 'selected' : '' %>>Ruim</option>
          <option value="razoável" <%= qs === 'razoável' ? 'selected' : '' %>>Razoável</option>
          <option value="boa" <%= qs === 'boa' ? 'selected' : '' %>>Boa</option>
        </select>

        <label for="aguaMl">Água ingerida (ml):</label>
        <input type="number" id="aguaMl" name="aguaMl" required value="<%= typeof aguaMl !== 'undefined' ? aguaMl : '' %>">

        <label for="humor">Humor:</label>
        <select id="humor" name="humor" required>
        <option value="1" <%= humor === '1' ? 'selected' : '' %>>😞 Muito Ruim</option>
        <option value="2" <%= humor === '2' ? 'selected' : '' %>>😕 Ruim</option>
        <option value="3" <%= humor === '3' ? 'selected' : '' %>>😐 Neutro</option>
        <option value="4" <%= humor === '4' ? 'selected' : '' %>>😊 Bom</option>
        <option value="5" <%= humor === '5' ? 'selected' : '' %>>😁 Excelente</option>
        </select>
        <label for="tipoAtividade">Tipo de Atividade:</label>
        <input type="text" id="tipoAtividade" name="tipoAtividade" value="<%= typeof tipoAtividade !== 'undefined' ? tipoAtividade : '' %>">

        <label for="intensidade">Intensidade:</label>
        <select id="intensidade" name="intensidade">
          <option value="sem atividade" <%= intensidadeVal === 'sem atividade' ? 'selected' : '' %>>Sem Atividade</option>
          <option value="leve" <%= intensidadeVal === 'leve' ? 'selected' : '' %>>Leve</option>
          <option value="moderada" <%= intensidadeVal === 'moderada' ? 'selected' : '' %>>Moderada</option>
          <option value="intensa" <%= intensidadeVal === 'intensa' ? 'selected' : '' %>>Intensa</option>
        </select>

        <label for="qualidadeAlimentacao">Qualidade da Alimentação:</label>
        <select id="qualidadeAlimentacao" name="qualidadeAlimentacao">
        <option value="1" <%= qualidadeAlimentacao === '1' ? 'selected' : '' %>>🍔 Muito Ruim</option>
        <option value="2" <%= qualidadeAlimentacao === '2' ? 'selected' : '' %>>🥪 Ruim</option>
        <option value="3" <%= qualidadeAlimentacao === '3' ? 'selected' : '' %>>🍛 Regular</option>
        <option value="4" <%= qualidadeAlimentacao === '4' ? 'selected' : '' %>>🥗 Boa</option>
        <option value="5" <%= qualidadeAlimentacao === '5' ? 'selected' : '' %>>🌿 Excelente</option>
        </select>
        <button type="submit">Salvar Registo</button>
      </form>
    </section>

    
  </div>
</body>
</html>
